# Backend Environment Variables
# Copy this to .env and fill in your actual values

# Database Connection String (get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/deliverydb?retryWrites=true&w=majority

# Server Port
PORT=5000

# Environment
NODE_ENV=production

# CORS - Add your frontend URLs
CORS_ORIGIN=https://delivery-frontend.vercel.app,https://delivery-admin.vercel.app,https://delivery-logistic.vercel.app

# JWT Secret (generate a random string for production)
JWT_SECRET=your_secret_key_here_make_it_random_and_long

# Email Configuration (optional - for notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# File Upload Settings
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Logging Level
LOG_LEVEL=info
